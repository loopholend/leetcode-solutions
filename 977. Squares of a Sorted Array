class Solution {
public:
    vector<int> sortedSquares(vector<int>& nums) {
        int n=nums.size();
        int left=0,right=n-1;
        vector<int> ans(n,0);
        for(int i=n-1;i>=0;i--){
            int val=0;
            if(abs(nums[left])<abs(nums[right])){
                val=nums[right];
                right--;
            }
            else{
                val=nums[left];
                left++;
            }
            ans[i]=val*val;
        }
        return ans;
    }
};
